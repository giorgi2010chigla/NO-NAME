# Shopify Storefront API Configuration
# Get these values from your Shopify Admin > Apps > Develop apps > Storefront API access

# Your Shopify store domain (e.g., "your-store.myshopify.com")
VITE_SHOPIFY_STORE_DOMAIN=your-store.myshopify.com

# Storefront API access token (public - safe to expose in frontend)
VITE_SHOPIFY_STOREFRONT_ACCESS_TOKEN=your-storefront-access-token

# Optional: Use Shopify Buy SDK instead of raw API
# VITE_USE_SHOPIFY_BUY_SDK=false